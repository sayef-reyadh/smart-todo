# --- Local development (LocalStack) ---
# Uncomment and set these when running locally with docker compose up
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_REGION=us-east-1
# DYNAMODB_TABLE_NAME=TASKS

# --- Production (real AWS) ---
# Do NOT set AWS_ENDPOINT_URL — boto3 will use the real AWS endpoint.
# Credentials are picked up automatically from:
#   - Environment variables: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_SESSION_TOKEN
#   - IAM role attached to EC2 / ECS / Lambda (recommended)
# AWS_REGION=us-east-1
# DYNAMODB_TABLE_NAME=TASKS
